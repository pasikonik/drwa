# ==========================================
# Nuxt Frontend Configuration
# ==========================================
# Public URL of the Directus CMS instance
NUXT_PUBLIC_DIRECTUS_URL=http://localhost:8055
DIRECTUS_URL=http://localhost:8055

# ==========================================
# Stripe (payments)
# ==========================================
# Server-only secret key (sk_test_… / sk_live_…)
STRIPE_SECRET_KEY=sk_test_xxx
# Webhook signing secret (whsec_…) — from `stripe listen` or dashboard endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Public publishable key (pk_test_… / pk_live_…)
NUXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# ==========================================
# Directus service token (server-only)
# ==========================================
# Static token of a Directus user/role allowed to create orders and
# update stock / workshop bookings. Never exposed to the client.
DIRECTUS_SERVICE_TOKEN=


MAILERLITE_API_KEY=twoj_tajny_klucz_api
MAILERLITE_GROUP_ID=id_twojej_grupy

# ==========================================
# Resend (formularz kontaktowy)
# ==========================================
# Klucz API Resend — używany do wysyłki wiadomości z /kontakt na kontakt@drwa.pl
RESEND_API_KEY=twoj_tajny_klucz_api

# ==========================================
# Google Tag Manager (analytics) — optional
# ==========================================
# Container ID (GTM-XXXXXXX). Loaded lazily on idle, production builds only.
# Leave empty to disable analytics entirely.
NUXT_PUBLIC_GTM_ID=